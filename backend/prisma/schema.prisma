// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Enum for tracking status to support scalable background jobs and filtering.
enum TrackingStatus {
  searched
  tracked
  archived
}

/// Region enum for geographical segmentation.
enum Region {
  dominican_republic
  latin_america
  usa
  unknown
}

/// Main model representing a Content Creator across multiple platforms (YouTube, Twitch, Kick, TikTok).
model Creator {
  id             String          @id @default(uuid())
  platform       String          // e.g., "youtube", "twitch", "kick", "tiktok"
  channelId      String          @unique @map("channel_id")
  slug           String          @unique
  username       String?         // Maintained for backwards compatibility
  displayName    String          @map("display_name")
  description    String?
  avatarUrl      String?         @map("avatar_url")
  bannerUrl      String?         @map("banner_url")
  verified       Boolean         @default(false)
  country        String?
  region         Region          @default(unknown)
  category       String?
  trackingStatus TrackingStatus  @default(searched) @map("tracking_status")
  isFeatured     Boolean         @default(false) @map("is_featured")
  
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  snapshots      CreatorSnapshot[]
  videos         Video[]
  dailyRankings  DailyRanking[]
  impacts        CreatorImpact[]

  @@map("creators")
  @@index([slug])
  @@index([platform])
  @@index([trackingStatus])
  @@index([region])
}

/// Stores historical data captures for a creator, enabling daily tracking and analytics.
model CreatorSnapshot {
  id             String   @id @default(uuid())
  creatorId      String   @map("creator_id")
  
  subscribers    BigInt   @default(0)
  totalViews     BigInt   @default(0) @map("total_views")
  totalVideos    Int      @default(0) @map("total_videos")
  avgViews       Float?   @default(0) @map("avg_views")
  engagementRate Float?   @default(0) @map("engagement_rate")
  
  snapshotDate   DateTime @default(now()) @map("snapshot_date")

  creator        Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_snapshots")
  @@index([creatorId, snapshotDate])
  @@index([snapshotDate])
}

/// Stores information about individual videos or streams from a creator.
model Video {
  id            String   @id @default(uuid())
  videoId       String   @unique @map("video_id")
  title         String
  thumbnail     String?  @map("thumbnail_url")
  views         BigInt   @default(0)
  publishedAt   DateTime @map("published_at")
  
  creatorId     String   @map("creator_id")
  creator       Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_videos")
  @@index([creatorId, publishedAt])
}

/// Stores historical ranking positions for a creator on a specific date.
model DailyRanking {
  id              String   @id @default(uuid())
  creatorId       String   @map("creator_id")
  rankingType     String   @map("ranking_type")
  rankingPosition Int      @map("ranking_position")
  rankingDate     DateTime @default(now()) @map("ranking_date")

  creator         Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("daily_rankings")
  @@index([rankingType, rankingDate])
}

/// Stores the calculated impact metrics for creators on specific snapshot dates.
model CreatorImpact {
  id             String   @id @default(uuid())
  creatorId      String   @map("creator_id")
  snapshotDate   DateTime @db.Date @map("snapshot_date")
  viewsVideos30d BigInt   @default(0) @map("views_videos_30d")
  viewsShorts30d BigInt   @default(0) @map("views_shorts_30d")
  impactTotal30d BigInt   @default(0) @map("impact_total_30d")
  videos30d      Int      @default(0) @map("videos_30d")
  shorts30d      Int      @default(0) @map("shorts_30d")
  createdAt      DateTime @default(now()) @map("created_at")

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, snapshotDate])
  @@index([impactTotal30d(sort: Desc)])
  @@index([viewsVideos30d(sort: Desc)])
  @@index([viewsShorts30d(sort: Desc)])
  @@index([snapshotDate])
  @@map("creator_impacts")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}
