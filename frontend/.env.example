# Viewlytics Frontend Environment Variables (Local)
#
# DO NOT COMMIT THIS FILE TO GITHUB.
# Create a copy named '.env' or '.env.local' and fill in your keys.

# URL of the frontend application itself (for metadata, share cards)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL of the Viewlytics backend API (FastAPI)
# All communication goes through backend to maintain API isolation.
NEXT_PUBLIC_API_URL=http://localhost:8000

# YouTube API Key (Server-side use only, prefix does not start with NEXT_PUBLIC_ to prevent exposure)
YOUTUBE_API_KEY=your_youtube_api_key_here
